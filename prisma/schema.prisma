generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Team {
  id          String       @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime     @default(now())
  members     TeamMember[]
  projects    Project[]
}

model Member {
  id             String       @id @default(cuid())
  name           String
  role           String
  email          String?
  address        String?
  isProfitMember Boolean      @default(false)
  createdAt      DateTime     @default(now())
  teams          TeamMember[]
  earnings       Earning[]
  worklogs       WorkLog[]
}

model TeamMember {
  id         String      @id @default(cuid())
  teamId     String
  memberId   String
  shadowOfId   String?
  internalRate Float?
  clientRate   Float?
  team       Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  member     Member      @relation(fields: [memberId], references: [id], onDelete: Cascade)
  shadowOf   TeamMember? @relation("ShadowOf", fields: [shadowOfId], references: [id])
  shadows    TeamMember[] @relation("ShadowOf")
  invoiceLines InvoiceLine[]

  @@unique([teamId, memberId])
}

model Customer {
  id          String               @id @default(cuid())
  name        String
  email       String?
  address     String?
  createdAt   DateTime             @default(now())
  projects    Project[]
  emailConfig CustomerEmailConfig?
}

model CustomerEmailConfig {
  id          String   @id @default(cuid())
  customerId  String   @unique
  receivers   String
  subject     String
  bodyHtml    String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Project {
  id          String    @id @default(cuid())
  name        String
  description String?
  status      String    @default("active")
  deadline    DateTime?
  createdAt   DateTime  @default(now())
  customerId  String?
  teamId      String?
  customer    Customer? @relation(fields: [customerId], references: [id])
  team        Team?     @relation(fields: [teamId], references: [id])
  invoices    Invoice[]
  worklogs    WorkLog[]
}

model Invoice {
  id          String        @id @default(cuid())
  number      String        @unique
  projectId   String
  status      String        @default("draft")
  invoiceDate DateTime
  dueDate     DateTime?
  notes       String?
  taxPercent  Float?
  emailSentAt DateTime?
  createdAt   DateTime      @default(now())
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lines       InvoiceLine[]
  earnings  Earning[]
  workLogs  WorkLog[]
}

model InvoiceLine {
  id           String  @id @default(cuid())
  invoiceId    String
  teamMemberId String
  hoursSpent   Float
  isFixed      Boolean @default(false)
  description  String?
  clientRate   Float
  subtotal     Float
  extraHours   Float   @default(0)
  extraAmount  Float   @default(0)
  paidAt       DateTime?
  invoice      Invoice    @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  teamMember   TeamMember @relation(fields: [teamMemberId], references: [id])
}

model Earning {
  id            String     @id @default(cuid())
  memberId      String
  invoiceId     String
  invoiceLineId String?
  amount        Float
  createdAt     DateTime   @default(now())
  member        Member     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  invoice       Invoice    @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model WorkLog {
  id          String   @id @default(cuid())
  projectId   String
  memberId    String
  hoursSpent  Float
  isExtra     Boolean  @default(false)
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  invoiceId   String?
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  member      Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  invoice     Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
}

model Settings {
  id    String  @id @default("singleton")
  smtpHost    String?
  smtpPort    Int?
  smtpUser    String?
  smtpPass    String?
  smtpFrom    String?
  backupEmail String?
}
